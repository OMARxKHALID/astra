# ──────────────────────────────────────────────────────────────────────────────
# ENVIRONMENT TEMPLATE (.env.example)
# Copy this file to .env.local and fill in the values.
# DO NOT put real passwords here.
# ──────────────────────────────────────────────────────────────────────────────

# --- Frontend & Browser ---
NEXT_PUBLIC_WS_URL=ws://localhost:3001
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Backend & Server ---
WS_PORT=3001
WS_HTTP_URL=http://localhost:3001
ALLOWED_ORIGINS=http://localhost:3000
JWT_SECRET=fuckthatshiittttt

# --- Redis / Upstash (Get these from Vercel/Upstash Dashboard) ---
# Both naming conventions are supported by the code
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# REDIS_KV_REST_API_URL=
# REDIS_KV_REST_API_TOKEN=

# --- Optional ---
OPENSUBTITLES_KEY=
NEXT_OUTPUT=standalone
NODE_ENV=development
