# ─── Client-side (exposed to browser) ───────────────────────────────────────
NEXT_PUBLIC_WS_URL=ws://localhost:3001
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Server-side only ────────────────────────────────────────────────────────
WS_PORT=3001
WS_HTTP_PORT=3002

# Comma-separated list of allowed origins for WebSocket connections
ALLOWED_ORIGINS=http://localhost:3000

# URL the Next.js API routes use to query live room state from the WS server
WS_HTTP_URL=http://localhost:3002

# ─── Production overrides (copy to .env.production.local) ────────────────────
# NEXT_PUBLIC_WS_URL=wss://your-ws-server.railway.app
# NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
# WS_HTTP_URL=http://your-ws-server.internal:3002
# ALLOWED_ORIGINS=https://your-app.vercel.app
